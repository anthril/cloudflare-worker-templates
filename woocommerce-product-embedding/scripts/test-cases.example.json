[
  {
    "_comment": "PRODUCT LOOKUP: Search by product name, verify the correct product appears in top results.",
    "query": "blue widget large",
    "type": "product_lookup",
    "expect": {
      "top_k": 5,
      "must_contain_any": ["Blue Widget", "Large Widget"],
      "min_score": 0.6
    }
  },
  {
    "query": "organic cotton t-shirt black",
    "type": "product_lookup",
    "expect": {
      "top_k": 5,
      "must_contain_any": ["Cotton T-Shirt", "Organic Cotton"],
      "min_score": 0.6
    }
  },
  {
    "query": "wireless bluetooth headphones",
    "type": "product_lookup",
    "expect": {
      "top_k": 5,
      "must_contain_any": ["Wireless Headphones", "Bluetooth"],
      "min_score": 0.6
    }
  },
  {
    "query": "stainless steel water bottle 750ml",
    "type": "product_lookup",
    "expect": {
      "top_k": 5,
      "must_contain_any": ["Water Bottle", "Stainless Steel"],
      "min_score": 0.6
    }
  },

  {
